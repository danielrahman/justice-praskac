  "analysis_overview": "Directcom, s.r.o. je stabilní společnost založená v roce 2009, kterou od počátku vede Ing. Martin Smola. V roce 2020 přibyl druhý jednatel a společník Radek Václavík, jinak firma nevykazuje žádné změny v názvu, sídle ani vedení. Účetní závěrky za roky 2022–2024 jsou podávány pravidelně prostřednictvím správce daně, ale bez strojově čitelných finančních metrik nelze hodnotit ekonomickou výkonnost.",
  "data_quality_note": "Data z justice.cz jsou kompletní po formální stránce, ale chybí konkrétní finanční metriky – nelze hodnotit ziskovost, zadlužení ani růst.",
  "insight_summary": [
    {
      "title": "Stabilní vlastnická a řídící struktura",
      "detail": "Od založení v roce 2009 vede firmu Ing. Martin Smola, v říjnu 2020 přibyl druhý jednatel Radek Václavík. Oba jsou zároveň společníci, žádné další změny ve vedení ani vlastnictví neproběhly."
    },
    {
      "title": "Pravidelné podávání účetních závěrek",
      "detail": "Účetní závěrky za roky 2022, 2023 a 2024 byly podány včas prostřednictvím správce daně (květen následujícího roku), bez viditelných prodlev nebo opomenutí."
    },
    {
      "title": "Žádné změny v základních údajích",
      "detail": "Firma nemá zaznamenanou žádnou změnu obchodního jména ani sídla od vzniku, což naznačuje kontinuitu a absenci restrukturalizací."
    }
  ],
  "deep_insights": [
    {
      "title": "Chybějící finanční metriky",
      "detail": "Účetní závěrky jsou v rejstříku dostupné, ale bez extrahovaných čísel (aktiva, výnosy, zisk, závazky) nelze posoudit ekonomickou kondici, trendy růstu ani zadluženost."
    },
    {
      "title": "Rozšíření vedení v roce 2020",
      "detail": "Přidání Radka Václavíka jako jednatele a společníka v říjnu 2020 může signalizovat kapitálové posílení nebo rozšíření kompetencí, ale bez finančních dat nelze dopad vyhodnotit."
    },
    {
      "title": "Dlouhodobá kontinuita",
      "detail": "Firma existuje od roku 2009 bez zjevných turbulencí v rejstříku – žádné insolvence, exekuce ani výmazy nejsou v datech zmíněny, což je pozitivní signál stability."
    }
  ],
  "praskac": [
    {
      "title": "Žádné červené vlajky v rejstříku",
      "detail": "V dostupných veřejných záznamech není vidět opožděné podání listin, změny vedení pod tlakem, ani jiné formální nesrovnalosti. Bez finančních dat ale nelze vyloučit skryté problémy."
    },
    {
      "title": "Neprůhledná ekonomická realita",
      "detail": "Absence strojově čitelných finančních údajů znamená, že nelze ověřit, zda firma generuje zisk, jak je zadlužená, nebo zda má dostatek kapitálu. Pro seriózní due diligence je nutné sehnat plné účetní závěrky."
    }
  ],
