  "analysis_overview": "SPR Building, s.r.o. je od roku 2008 ostravská stavební firma s jedním jednatelem (Tomáš Häring od 2013) a jediným společníkem RT TORAX Development, a.s. Firma vykazuje minimální tržby (0,89–6,9 mil. Kč), v letech 2019–2020 provozní ztráty, v roce 2021 nečekaný provozní zisk 10,57 mil. Kč a v roce 2022 návrat k symbolickému zisku 0,36 mil. Kč. Vlastní kapitál je stabilní kolem 41–52 mil. Kč, ale za roky 2023 a 2024 chybí finanční data navzdory podaným účetním závěrkám.",
  "data_quality_note": "Finanční data jsou k dispozici pouze za roky 2019–2022, za 2023 a 2024 jsou podány účetní závěrky bez extrahovaných metrik, což znemožňuje posouzení aktuálního stavu.",
  "insight_summary": [
    {
      "title": "Minimální obchodní aktivita",
      "detail": "Tržby se pohybují v rozmezí 0,89–6,9 mil. Kč ročně, což je extrémně nízké pro firmu s aktivy kolem 66–91 mil. Kč. Firma spíše drží majetek než aktivně podniká."
    },
    {
      "title": "Jednorázový skok zisku v roce 2021",
      "detail": "Provozní zisk 10,57 mil. Kč v roce 2021 při tržbách jen 0,89 mil. Kč naznačuje mimořádnou operaci (prodej majetku, přecenění), nikoli běžnou činnost. V roce 2022 zisk klesl na 0,36 mil. Kč."
    },
    {
      "title": "Stabilní kapitálová struktura",
      "detail": "Vlastní kapitál se drží mezi 41–52 mil. Kč, poměr vlastního kapitálu kolísá mezi 57–78 %. Firma není kriticky zadlužená, ale závazky vzrostly v roce 2022 na 38,87 mil. Kč."
    },
    {
      "title": "Chybějící aktuální data",
      "detail": "Za roky 2023 a 2024 jsou podány účetní závěrky, ale bez extrahovaných finančních metrik. Nelze posoudit, zda firma pokračuje v provozu nebo stagnuje."
    }
  ],
  "deep_insights": [
    {
      "title": "Neobvyklý profil: vysoká aktiva, nulové tržby",
      "detail": "Firma s aktivy 66–91 mil. Kč generuje tržby pod 7 mil. Kč ročně. To odpovídá spíše holdingové nebo majetkové struktuře než aktivní stavební firmě."
    },
    {
      "title": "Stabilní vedení a vlastnictví",
      "detail": "Jednatel Tomáš Häring ve funkci od 2013, jediný společník RT TORAX Development, a.s. Žádné změny v názvu, sídle ani vedení – firma je pod pevnou kontrolou."
    },
    {
      "title": "Pokles aktiv po roce 2021",
      "detail": "Aktiva klesla z 71,35 mil. Kč (2019) na 66,46 mil. Kč (2021), pak vzrostla na 91,44 mil. Kč (2022). Bez dat za 2023–2024 nelze určit, zda trend pokračuje."
    },
    {
      "title": "Nárůst závazků v roce 2022",
      "detail": "Závazky vzrostly z 14,53 mil. Kč (2021) na 38,87 mil. Kč (2022), což snížilo poměr vlastního kapitálu z 78,1 % na 57,2 %. Důvod není z dat patrný."
    }
  ],
  "praskac": [
    {
      "title": "Extrémní zpoždění účetní závěrky za 2020",
      "detail": "Účetní závěrka za rok 2020 byla založena do Sbírky listin až 19. 12. 2022, tedy téměř 2 roky po konci účetního období. To je závažné porušení zákonné lhůty."
    },
    {
      "title": "Opakované pozdní podání za 2021 a 2022",
      "detail": "Závěrka za 2021 založena s 354denním zpožděním, za 2022 s 268denním zpožděním. Firma systematicky nedodržuje lhůty pro zveřejnění účetních závěrek."
    },
    {
      "title": "Nevysvětlený provozní zisk 10,57 mil. Kč v roce 2021",
      "detail": "Při tržbách 0,89 mil. Kč dosáhla firma provozního zisku 10,57 mil. Kč. Bez přístupu k přílohám účetní závěrky nelze ověřit, zda šlo o prodej majetku, dotaci nebo jinou mimořádnou operaci."
    },
    {
      "title": "Chybějící finanční metriky za 2023 a 2024",
      "detail": "Účetní závěrky jsou podány, ale bez extrahovaných dat. Není jasné, zda firma pokračuje v činnosti, nebo je v útlumu. Transparentnost je minimální."
