# Required
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Turso
DATABASE_URL=libsql://your-db-name-organization.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Cloudflare R2
S3_ENDPOINT=https://<your-account-id>.r2.cloudflarestorage.com
S3_BUCKET=justice-praskac
S3_ACCESS_KEY_ID=your-r2-access-key-id
S3_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Optional — AI configuration
JUSTICE_ENABLE_AI=1
JUSTICE_AI_MODEL=claude-sonnet-4-20250514
JUSTICE_AI_TIMEOUT_SECONDS=90

# Optional — server
JUSTICE_LOG_LEVEL=INFO
JUSTICE_CORS_ORIGINS=
PORT=8000
